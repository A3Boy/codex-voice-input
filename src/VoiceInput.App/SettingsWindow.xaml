<Window
    x:Class="VoiceInput.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Codex Voice Input 设置">
    <Grid x:Name="Root" RequestedTheme="Light">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="62" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarDragRegion" Grid.Row="0" Padding="20,0,138,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Text="设置"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <Button
                x:Name="ThemeButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Click="ThemeButton_Click"
                ToolTipService.ToolTip="切换深色模式">
                <FontIcon x:Name="ThemeIcon" Glyph="&#xE708;" FontSize="15" />
            </Button>
        </Grid>

        <TabView
            Grid.Row="1"
            IsAddTabButtonVisible="False"
            >
            <TabViewItem Header="设置" IsClosable="False">
                <ScrollViewer Padding="24,12,24,4" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="15">
                        <ComboBox
                            x:Name="MicrophoneBox"
                            Header="麦克风"
                            HorizontalAlignment="Stretch" />

                        <TextBox
                            x:Name="HotkeyBox"
                            Header="全局快捷键"
                            PlaceholderText="Ctrl+Alt+Space" />

                        <ToggleSwitch
                            x:Name="ShowAfterInputToggle"
                            Header="输入后保留胶囊"
                            OffContent="关闭"
                            OnContent="开启" />

                        <TextBlock
                            x:Name="StatusText"
                            MinHeight="20"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="识别记录" IsClosable="False">
                <Grid Padding="18,10,18,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button
                        HorizontalAlignment="Right"
                        Content="清空记录"
                        Click="ClearHistory_Click" />
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <ListView x:Name="HistoryList" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock
                                                Text="{Binding DisplayTime}"
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock
                                                Text="{Binding Text}"
                                                FontSize="13"
                                                MaxLines="3"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            Tag="{Binding Text}"
                                            Click="CopyHistory_Click"
                                            ToolTipService.ToolTip="复制">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock
                            x:Name="EmptyHistoryText"
                            Text="暂无识别记录"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Grid>
            </TabViewItem>
        </TabView>

        <Grid Grid.Row="2" Padding="24,10,24,14" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="取消" Click="Cancel_Click" />
            <Button Grid.Column="2" Content="保存" Style="{StaticResource AccentButtonStyle}" Click="Save_Click" />
        </Grid>
    </Grid>
</Window>
