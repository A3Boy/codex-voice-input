<Window
    x:Class="VoiceInput.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="Root" Width="332" Height="56" Background="#FAFCFF">
        <Border
            x:Name="Capsule"
            Width="332"
            Height="56"
            CornerRadius="28"
            BorderBrush="#3D8492A6"
            BorderThickness="1"
            Background="#FAFCFF">

            <Grid ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="42" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="MainButton"
                    Grid.Column="0"
                    Width="44"
                    Height="44"
                    Margin="6,0,0,0"
                    HorizontalAlignment="Left"
                    Click="MainButton_Click"
                    Background="#FFF8FAFD"
                    BorderBrush="#297D8DA4"
                    CornerRadius="22">
                    <FontIcon x:Name="MainIcon" Glyph="&#xE720;" FontSize="20" />
                </Button>

                <Grid Grid.Column="1" Margin="14,0,8,0" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="StatusText"
                        Text="点击开始语音输入"
                        Foreground="#6F7B8D"
                        FontSize="14"
                        TextTrimming="CharacterEllipsis" />
                    <StackPanel x:Name="Waveform" Orientation="Horizontal" Spacing="4" Visibility="Collapsed">
                        <Rectangle Width="3" Height="8" RadiusX="2" RadiusY="2" Fill="#247CFF" />
                        <Rectangle Width="3" Height="18" RadiusX="2" RadiusY="2" Fill="#247CFF" />
                        <Rectangle Width="3" Height="12" RadiusX="2" RadiusY="2" Fill="#247CFF" />
                        <Rectangle Width="3" Height="24" RadiusX="2" RadiusY="2" Fill="#247CFF" />
                        <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Fill="#247CFF" />
                        <Rectangle Width="3" Height="20" RadiusX="2" RadiusY="2" Fill="#247CFF" />
                        <TextBlock x:Name="TimerText" Margin="10,0,0,0" Text="00:00" Foreground="#4C5B6F" />
                    </StackPanel>
                </Grid>

                <Button Grid.Column="2" Width="32" Height="32" Background="Transparent" BorderThickness="0" Click="SettingsButton_Click">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                </Button>

                <Button Grid.Column="3" Width="32" Height="32" Background="Transparent" BorderThickness="0" Click="CloseButton_Click">
                    <FontIcon Glyph="&#xE711;" FontSize="16" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
